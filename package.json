{
  "name": "yardarm",
  "version": "0.4.2",
  "description": "Standalone Electron desktop UI for Mastra Code",
  "author": "Yardarm contributors",
  "main": "out/main/index.js",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:commands": "node scripts/check-command-coverage.mjs",
    "postinstall": "electron-builder install-app-deps",
    "stage:agent-runtime": "node scripts/build-agent-runtime.mjs",
    "package": "npm run stage:agent-runtime && electron-vite build && electron-builder --dir",
    "dist": "npm run stage:agent-runtime && electron-vite build && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "@trpc/server": "^11.18.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "node-pty": "^1.1.0",
    "simple-git": "^3.36.0",
    "superjson": "^2.2.6",
    "trpc-electron": "^0.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@git-diff-view/file": "^0.1.7",
    "@git-diff-view/react": "^0.1.7",
    "@mastra/code-sdk": "1.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "jotai": "^2.20.2",
    "lucide-react": "^1.25.0",
    "mastracode": "0.32.1",
    "monaco-editor": "^0.55.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.64.0",
    "undici": "^8.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "node-pty",
      "esbuild",
      "bufferutil",
      "onnxruntime-node",
      "protobufjs",
      "@ast-grep/napi"
    ]
  }
}
